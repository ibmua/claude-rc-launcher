# Include this inside your TLS server { } block, e.g.:
#   include /etc/nginx/snippets/rc-launcher.conf;
# Replace <PREFIX> with the contents of prefix.txt.

location /<PREFIX>/ {
    proxy_pass http://127.0.0.1:9137;
    proxy_set_header X-Forwarded-For $remote_addr;
    proxy_read_timeout 120s;
    # No caching, no logging the secret path to access logs if you prefer:
    # access_log off;
}
